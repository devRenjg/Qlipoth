# LLM 配置(也可在设置页填写，仅管理员可改)
LLM_API_KEY=
LLM_BASE_URL=https://api.example.com
LLM_MODEL=your-model-name
LLM_API_FORMAT=openai

# CORS 前端 origin 白名单(逗号分隔)
QLIPOTH_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# 可选：Confluence 风格 wiki provider(不配置则不启用，公开仓库默认空)
CONFLUENCE_BASE_URL=
CONFLUENCE_COOKIE_FILE=
CONFLUENCE_AUTH_COOKIE=SESSIONID

# 生产 HTTPS 部署设为 1 启用 Cookie Secure 属性(本地开发留空)
QLIPOTH_COOKIE_SECURE=

# 直播日历房间地址URL前缀(生产用真实直播域名，本地/公开仓库用占位符)
LIVE_ROOM_URL_PREFIX=https://live.example.com/
